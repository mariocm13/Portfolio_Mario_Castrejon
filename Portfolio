<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mario Castrejón Martín — Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green-dark:   #085041;
      --green-mid:    #0F6E56;
      --green:        #1D9E75;
      --green-light:  #9FE1CB;
      --green-pale:   #E1F5EE;
      --text:         #1a1a18;
      --text-muted:   #6b6b66;
      --border:       rgba(0,0,0,0.10);
      --bg:           #fafaf8;
      --bg-card:      #ffffff;
      --radius:       12px;
      --radius-sm:    8px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 16px;
      line-height: 1.6;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      height: 60px;
      background: rgba(250,250,248,0.88);
      backdrop-filter: blur(12px);
      border-bottom: 0.5px solid var(--border);
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.15s;
    }

    .nav-links a:hover { color: var(--green); }

    /* ── SECTIONS ── */
    section { padding: 6rem 2.5rem; max-width: 900px; margin: 0 auto; }

    /* ── HERO ── */
    #hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 80px;
    }

    .available-badge {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--green-mid);
      background: var(--green-pale);
      border: 0.5px solid var(--green-light);
      padding: 5px 12px;
      border-radius: 20px;
      margin-bottom: 1.5rem;
      width: fit-content;
    }

    .available-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--green);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: 0.5; transform: scale(0.8); }
    }

    h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3rem, 8vw, 5.5rem);
      font-weight: 700;
      line-height: 1.03;
      letter-spacing: -0.025em;
      margin-bottom: 1rem;
    }

    .hero-sub {
      font-size: 1rem;
      font-weight: 400;
      color: var(--text-muted);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }

    .hero-desc {
      max-width: 560px;
      font-size: 1.05rem;
      color: var(--text-muted);
      line-height: 1.75;
      margin-bottom: 2.5rem;
    }

    .hero-contacts {
      display: flex;
      flex-wrap: wrap;
      gap: 1.2rem;
      margin-bottom: 2.5rem;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .contact-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--green);
    }

    .btn-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 10px 20px;
      border-radius: var(--radius-sm);
      text-decoration: none;
      border: 0.5px solid var(--border);
      color: var(--text);
      background: transparent;
      transition: all 0.15s;
      cursor: pointer;
    }

    .btn:hover { background: #f0f0ec; }

    .btn-primary {
      background: var(--green-mid);
      color: #fff;
      border-color: var(--green-mid);
    }

    .btn-primary:hover { background: var(--green-dark); border-color: var(--green-dark); color: #fff; }

    /* ── SECTION LABEL ── */
    .section-label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 0.6rem;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 2.5rem;
      line-height: 1.1;
    }

    hr.divider {
      border: none;
      border-top: 0.5px solid var(--border);
      margin: 0;
    }

    /* ── PROJECTS ── */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
    }

    .project-card {
      background: var(--bg-card);
      border: 0.5px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .project-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.07);
    }

    .project-video-wrap {
      width: 100%;
      aspect-ratio: 16/9;
      background: #111;
      overflow: hidden;
    }

    .project-video-wrap video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .project-img {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      background: var(--green-pale);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .project-img-placeholder {
      width: 100%;
      aspect-ratio: 16/9;
      background: var(--green-pale);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .project-img-placeholder span {
      font-size: 2.5rem;
    }

    .project-body { padding: 1.25rem; }

    .project-tag {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--green-mid);
      background: var(--green-pale);
      padding: 3px 8px;
      border-radius: 20px;
      margin-bottom: 0.6rem;
    }

    .project-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
      line-height: 1.3;
    }

    .project-desc {
      font-size: 0.83rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ── SKILLS ── */
    .skills-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    .skill-card {
      background: var(--bg-card);
      border: 0.5px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
    }

    .skill-card h3 {
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }

    .skill-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }

    .skill-row:last-child { margin-bottom: 0; }

    .skill-name {
      font-size: 0.82rem;
      min-width: 110px;
    }

    .skill-bar {
      flex: 1;
      height: 3px;
      background: #ebebea;
      border-radius: 2px;
      overflow: hidden;
    }

    .skill-fill {
      height: 100%;
      background: var(--green);
      border-radius: 2px;
    }

    .skill-lv {
      font-size: 0.7rem;
      color: var(--text-muted);
      min-width: 50px;
      text-align: right;
    }

    /* ── EXPERIENCE ── */
    .exp-item {
      display: grid;
      grid-template-columns: 130px 1fr;
      gap: 1.5rem;
      padding: 2rem 0;
      border-bottom: 0.5px solid var(--border);
    }

    .exp-item:last-child { border-bottom: none; }

    .exp-date {
      font-size: 0.78rem;
      color: var(--text-muted);
      padding-top: 3px;
    }

    .exp-role {
      font-size: 1rem;
      font-weight: 500;
      margin-bottom: 3px;
    }

    .exp-org {
      font-size: 0.82rem;
      color: var(--green-mid);
      margin-bottom: 0.75rem;
    }

    .exp-tasks {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .exp-tasks li {
      font-size: 0.83rem;
      color: var(--text-muted);
      padding-left: 14px;
      position: relative;
    }

    .exp-tasks li::before {
      content: '';
      position: absolute;
      left: 0; top: 8px;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--green-light);
    }

    /* ── CONTACT ── */
    #contacto {
      background: var(--green-dark);
      color: #fff;
      max-width: 100%;
      padding: 5rem 2.5rem;
      text-align: center;
    }

    #contacto .section-label { color: var(--green-light); }

    #contacto .section-title { color: #fff; margin-bottom: 1rem; }

    #contacto p { color: rgba(255,255,255,0.65); margin-bottom: 2rem; font-size: 1rem; }

    #contacto .btn {
      border-color: rgba(255,255,255,0.25);
      color: #fff;
    }

    #contacto .btn:hover { background: rgba(255,255,255,0.1); }

    #contacto .btn-primary {
      background: var(--green);
      border-color: var(--green);
      color: #fff;
    }

    #contacto .btn-primary:hover { background: var(--green-mid); }

    /* ── FOOTER ── */
    footer {
      background: var(--green-dark);
      border-top: 0.5px solid rgba(255,255,255,0.08);
      text-align: center;
      padding: 1.5rem;
      font-size: 0.75rem;
      color: rgba(255,255,255,0.35);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 640px) {
      nav { padding: 0 1.25rem; }
      nav .nav-links { display: none; }
      section { padding: 4rem 1.25rem; }
      .exp-item { grid-template-columns: 1fr; gap: 0.25rem; }
      .skills-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
